rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isValidReport(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ['full', 'pm'] &&
             data.analyzedData is list &&
             data.stats is map &&
             data.createdAt is timestamp;
    }

    match /reports/{reportId} {
      // Allowing public read, create, and delete for now to match current app behavior
      // while adding validation for creation.
      allow read, delete: if true;
      allow create: if isValidReport(request.resource.data);
      allow update: if false; // Reports are immutable in this app
    }
  }
}
